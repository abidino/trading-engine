# ─────────────────────────────────────────────────────────────────────────────
# UI ↔ backend wiring
#
# The browser talks to THIS Nuxt app same-origin at /api/v1/**. A server-side
# proxy (server/routes/api/v1/[...].ts) forwards those calls to the backend and
# adds HTTP Basic auth. Credentials below are SERVER-ONLY and never shipped to
# the browser. On Vercel, set these as Environment Variables.
# ─────────────────────────────────────────────────────────────────────────────

# Real backend base URL (no trailing slash), e.g. https://trading-engine.onrender.com
NUXT_API_PROXY_TARGET=http://localhost:4650

# HTTP Basic credentials the proxy sends to the backend
# (must match backend APP_AUTH_USERNAME / APP_AUTH_PASSWORD)
NUXT_API_USERNAME=admin
NUXT_API_PASSWORD=changeme

# Optional: leave EMPTY to use the same-origin proxy (recommended).
# Set to the backend URL only if you want the browser to call it directly
# (bypasses the proxy → exposes credentials, requires CORS). Not recommended.
# NUXT_PUBLIC_API_BASE_URL=
